{
  "mcpServers": {
    "open-fem-agent": {
      "command": "python",
      "args": ["-m", "server"],
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "FOURC_ROOT": "${HOME}/4C",
        "FOURC_BINARY": "${HOME}/4C/build/4C",
        "LD_LIBRARY_PATH": "/opt/4C-dependencies/lib",
        "FENICS_PYTHON": "${HOME}/miniconda3/envs/fenics/bin/python",
        "PYVISTA_OFF_SCREEN": "true"
      }
    }
  }
}
